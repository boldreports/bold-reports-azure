                                            <i class="su su-tick"></i>
                                            <span class="search-option">[[[Name (A-Z)]]]</span>
                                        </a>
                                    </li>
                                    <li ng-class="{selected : selectedCategorySort === 'Name' && categorySortDirection == 'descending'}" ng-click="setSelectedSortCategory($event, 'Name', 'descending')">
