                                                        <ul class="category-settings">
                                                            <li class="dropdown category-context-menu" ng-if="!isTablet">
                                                            <span class="dropdown-bs-toggle no-margin no-padding su su-settings-1" title="[[[Actions]]]" data-bs-placement="top" data-bs-toggle="dropdown">
