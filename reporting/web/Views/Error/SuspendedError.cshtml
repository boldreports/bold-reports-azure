@using Syncfusion.Server.Base.Helpers

@{
    Layout = null;
    var globalAppSettings = _globalAppSettings;
    var cdnLink = string.Empty;
    var faviconLogo = string.Empty;
    var reportServerResourceUrl = string.Empty;
    var subscriptionLink = ServerAppConfig.AppSettings.EndPoints.TenantAppUrl + "sites/" + _globalAppSettings.SystemSettings.TenantId + "/subscription";
    if (ServerAppConfig.IsSelfHosted)
    {
        cdnLink = (Context.Request.PathBase.ToString().Equals("/") ? string.Empty : Context.Request.PathBase.ToString()) + ServerAppConfig.AppSettings.EndPoints.CdnLink + "/cdn/images";
        reportServerResourceUrl = (Context.Request.PathBase + ServerAppConfig.AppSettings.EndPoints.CdnLink).TrimEnd('/');
        faviconLogo = ServerAppConfig.InternalAppIdpUrl + "/ums/logos?type=favicon";
    }
    else
    {
        cdnLink = @GlobalAppSettings.CdnDomain;
        reportServerResourceUrl = ServerAppConfig.AppSettings.EndPoints.CdnLink.TrimEnd('/');
        faviconLogo = reportServerResourceUrl + "/cdn/images/application/" + @ServerAppConfig.AppSettings.AppBranding.Identifier + "/" + @IconFileNames.Favicon;
    }
    var faviconFallbackPath = reportServerResourceUrl + "/cdn/images/application/" + ServerAppConfig.AppSettings.AppBranding.Identifier + "/" + IconFileNames.Favicon;
    var url = new Uri(Context.Request.GetDisplayUrl());
    var dns = url.GetLeftPart(UriPartial.Authority);
    var activateTenantUrl = $"{dns}/reporting/site/{globalAppSettings.SystemSettings.TenantIdentifier}/activate-suspended-tenant";
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Site Suspended - @GlobalAppSettings.BrandingDisplayName</title>
    <environment include="Development,CloudDevelopment">
        <link rel="stylesheet" asp-append-version="true" href="@reportServerResourceUrl/cdn/css/layout.css" integrity="@IntegrityTagHelper.GetIntegrity("wwwroot/cdn/css/layout.css")" crossorigin="anonymous" />
        <link rel="stylesheet" asp-append-version="true" href="@reportServerResourceUrl/cdn/css/error-page.css" integrity="@IntegrityTagHelper.GetIntegrity("wwwroot/cdn/css/error-page.css")" crossorigin="anonymous" />
        <link rel="stylesheet" asp-append-version="true" href="@ServerAppConfig.CustomFontUrl(globalAppSettings?.SystemSettings?.FontPreference, reportServerResourceUrl)" />
    </environment>
    <environment exclude="Development,CloudDevelopment">
        <link rel="stylesheet" asp-append-version="true" href="@reportServerResourceUrl/cdn/css/layout.min.css" integrity="@IntegrityTagHelper.GetIntegrity("wwwroot/cdn/css/layout.min.css")" crossorigin="anonymous" />
        <link rel="stylesheet" asp-append-version="true" href="@reportServerResourceUrl/cdn/css/error-page.min.css" integrity="@IntegrityTagHelper.GetIntegrity("wwwroot/cdn/css/error-page.min.css")" crossorigin="anonymous" />
        <link rel="stylesheet" asp-append-version="true" href="@ServerAppConfig.CustomFontUrl(globalAppSettings?.SystemSettings?.FontPreference, reportServerResourceUrl)" />
    </environment>

    @await Html.PartialAsync("~/Views/Shared/_LoaderIcon.cshtml")
<link rel="icon" href="@faviconLogo" id="favicon-link" />
</head>
<body>
    <div class="suspended-container-bg">
        <div class="suspended-conatiner" id="suspended-conatiner">
            <div id="suspended-main-div">
                <div class="suspended-logo">
                    <img src="@reportServerResourceUrl/cdn/images/static/error-pages/v1/suspended.svg" />
                </div>
                <div class="suspended-secondary-div">
                    @if (ServerAppConfig.Sandbox.Reports.Enabled)
                    {
                        <div class="suspended-page-title">
                            [[[Your Report Access is Inactive]]]
                        </div>
                        <div class="suspended-page-content">
                            [[[Your subscription was paused due to inactivity. Do not worry, your data is safe and can be restored.]]]
                        </div>
                        <div class="suspended-page-content">
                            [[[To continue using your report, simply reactivate below.]]]
                        </div>
                        <div>
                            <a href="@activateTenantUrl" class="e-control e-btn e-lib e-primary e-flat" id="activate-suspended-tenant">[[[Reactivate My Access]]]</a>
                        </div>
                    }
                    else
                    {
                        <div class="suspended-page-title">
                            Suspended
                        </div>
                        <div class="suspended-page-content">
                            [[[Subscription to the reports have been suspended.]]]
                            @if (!ServerAppConfig.IsSelfHosted)
                            {
                                <div>
                                    <span>[[[If you are a subscription administrator for ]]]@(globalAppSettings.SystemSettings.OrganizationName)[[[, you can activate your suspended site ]]]<a href='@subscriptionLink' class='redirect-link' target='_blank'>[[[here.]]]</a></span>
                                </div>
                            }
                            else
                            {
                                <div>[[[Please contact your System Administrator for more details.]]]</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <script nonce="@Context.Items["ScriptNonce"]">
        document.addEventListener("DOMContentLoaded", function () {
            var faviconLinkElement = document.getElementById("favicon-link");
            var fallbackFaviconPath = '@faviconFallbackPath';
            var faviconValidationImageObj = new Image();
            faviconValidationImageObj.src = faviconLinkElement.href;

            faviconValidationImageObj.addEventListener("error", function () {
                faviconLinkElement.href = fallbackFaviconPath;
            });
        });
    </script>
</body>
</html>
